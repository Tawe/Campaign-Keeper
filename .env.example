# Firebase client-side (safe to expose in browser)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# App URL (used for magic link redirect and email links)
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email — SendGrid (used for login links)
SENDGRID_API_KEY=SG...
EMAIL_FROM=noreply@yourdomain.com
EMAIL_NAME=Campaign Tracker

# Email — Resend (used for reminder emails)
RESEND_API_KEY=re_...
RESEND_FROM_ADDRESS=noreply@yourdomain.com

# Cron secret — protect the /api/cron/send-reminders endpoint
CRON_SECRET=

# Set to "true" to connect to Firebase Emulator Suite instead of production
NEXT_PUBLIC_FIREBASE_EMULATOR=true

# Firebase Admin — server-only (never expose). Paste the service account JSON as a single-line string.
# Not needed when NEXT_PUBLIC_FIREBASE_EMULATOR=true
FIREBASE_SERVICE_ACCOUNT=

# Private S3 bucket for portrait uploads
CAMPAIGN_KEEPER_AWS_REGION=
CAMPAIGN_KEEPER_AWS_ACCESS_KEY_ID=
CAMPAIGN_KEEPER_AWS_SECRET_ACCESS_KEY=
CAMPAIGN_KEEPER_AWS_SESSION_TOKEN=
CAMPAIGN_KEEPER_S3_BUCKET=
# Optional for non-AWS S3-compatible providers
CAMPAIGN_KEEPER_S3_ENDPOINT=
CAMPAIGN_KEEPER_S3_FORCE_PATH_STYLE=false
