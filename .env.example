# Firebase client-side (safe to expose in browser)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# App URL (used for magic link redirect)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to "true" to connect to Firebase Emulator Suite instead of production
NEXT_PUBLIC_FIREBASE_EMULATOR=true

# Firebase Admin — server-only (never expose). Paste the service account JSON as a single-line string.
# Not needed when NEXT_PUBLIC_FIREBASE_EMULATOR=true
FIREBASE_SERVICE_ACCOUNT=

# Private S3 bucket for portrait uploads
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
S3_BUCKET=
# Optional for non-AWS S3-compatible providers
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false
